# Makefile for self_test testbenk

SIM ?= ghdl
TOPLEVEL_LANG ?= vhdl

EXTRA_ARGS += --std=08
COCOTB_HDL_TIMEPRECISION = 1fs

TOPLEVEL = self_test

# Sett TICK_LIMIT til 99 for rask simulering (100 sykluser = 1 "tick")
SIM_ARGS += -gTICK_LIMIT=99
SIM_ARGS += --wave=$(TOPLEVEL).ghw

VHDL_SOURCES += $(PWD)/../src/self_test.vhd

COCOTB_TEST_MODULES = tb_self_test

include $(shell cocotb-config --makefiles)/Makefile.sim

clean::
	-@rm -rf __pycache__
	-@rm -rf sim_build